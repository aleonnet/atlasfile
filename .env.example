APP_ENV=dev

# ── Pasta raiz de projetos (OBRIGATÓRIO) ──
# Path absoluto no host onde ficam os projetos. Montado como /projects no container.
# Default recomendado: $HOME/Documents/Projects
# macOS: /Users/<user>/Documents/Projects
# Linux: /home/<user>/Documents/Projects
# Windows (WSL): /mnt/c/Users/<user>/Documents/Projects
PROJECTS_HOST_ROOT=/Users/your-user/Documents/Projects

# ── API do assistente LLM ──
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── CORS ──
# Se acessar o front por IP (ex.: http://192.168.1.5:5173), adicione aqui.
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.5:5173

# ── OpenSearch ──
OPENSEARCH_HOST=https://localhost:9200
OPENSEARCH_INDEX=atlasfile_documents
OPENSEARCH_USER=admin
# O install.sh gera uma senha única por instalação automaticamente.
# Instalação manual: defina uma senha forte (mín. 8 chars, com maiúscula,
# minúscula, número e símbolo — exigência do OpenSearch) nas DUAS variáveis.
OPENSEARCH_PASSWORD=Troque-Esta!Senha123
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Troque-Esta!Senha123

# ── Reconciliação automática ──
PROJECTS_ROOT=/projects
CLASSIFIER_DATASETS_ROOT=/projects/_ATLASFILE/classifier/datasets
AUTO_RECONCILE_INTERVAL_SECONDS=600
AUTO_RECONCILE_REINDEX_SEARCH=true

# ── Autenticação (API key + escopo de projeto) ──
# Default off (backward compat). Ligando, toda chamada exige Authorization: Bearer
# ou X-API-Key com uma key de config/api_keys.json (crie do api_keys.example.json;
# fica fora do git). A key do MCP vai em ATLASFILE_API_TOKEN (precisa existir no json).
# Porta 8001 (MCP) não valida key — mantenha-a interna/fechada na rede.
# API_AUTH_ENABLED=false
# ATLASFILE_API_TOKEN=atlas_sk_troque-esta-chave-mcp

# ── Embeddings / busca semântica ──
# Habilita embeddings por chunk no índice atlasfile_chunk_vectors (RAG híbrido).
# Falha de embedding nunca quebra a ingestão — o doc é indexado sem vetores e flagado.
# EMBEDDING_ENABLED=true
# Provider: "openai" (text-embedding-3-small, requer OPENAI_API_KEY) ou
# "fastembed" (local/ONNX, requer: pip install -r backend/requirements-local-embeddings.txt)
# EMBEDDING_PROVIDER=openai
# Modelo/dimensão: vazio/0 = default do provider. Trocar exige recriar o índice de
# vetores e rodar backend/scripts/backfill_embeddings.py --force.
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSION=0
# EMBEDDING_BATCH_SIZE=100

# ── Canais de mensagem (opcional) ──
# Habilita o subsistema de canais (Telegram, Discord, Slack, etc.).
# CHANNELS_ENABLED=false
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=  # Obtenha via @BotFather no Telegram
# TELEGRAM_MIRROR_RESPONSES=false  # Espelhar respostas do web para o Telegram (default: off)
