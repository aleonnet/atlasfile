    "routing_rules": [
      {
        "when_path_contains": [
          "output/"
        ],
        "route_to": "entregaveis",
        "confidence": 0.98
      },
      {
        "when_filename_contains": [
          "contrato",
          "fornecedor",
          "cliente",
          "preambulo"
        ],
        "route_to": "contratos_comunicacao",
        "confidence": 0.9
      },
      {
        "when_filename_contains": [
          "filiais",
          "cnpj",
          "estabelecimentos"
        ],
        "route_to": "societario_fiscal",
        "confidence": 0.9
      },
      {
        "when_filename_contains": [
          "cmdb",
          "ativo",
          "imobilizado",
          "doacao"
        ],
        "route_to": "ativos",
        "confidence": 0.9
      },
      {
        "when_filename_contains": [
          "colaboradores",
          "organograma",
          "gh_"
        ],
        "route_to": "pessoas",
        "confidence": 0.9
      }
    ],
    "confidence_thresholds": {
      "auto_route_min": 0.85,
      "triage_min": 0.5
    },
    "llm_policy": {
      "enabled": false,
      "provider": "openai",
      "model": "gpt-4.1",
      "mode": "tag_only",
      "allow_override_fields": [
        "document_type",
        "tags",
        "confidence",
        "topics"
      ],
      "override_guardrails": {
        "area_override_only_if_rule_confidence_below": 0.65,
        "require_explanation": true,
        "max_area_changes": 1
      }
    }
